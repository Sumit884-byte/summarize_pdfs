# Default: Arka LLM backend (provider: arka in config.yaml).
# Install with: pip install -e ".[arka]"
# Add provider keys to ~/.config/arka/.env (Gemini, Groq, Ollama, etc.). Run: arka doctor

# Supermemory (local by default — no API key required)
# MEMORY=local
# SUPERMEMORY_CONTAINER=summarize_pdfs
# Optional cloud sync:
# SUPERMEMORY_API_KEY=sm_...
# MEMORY=auto

# Optional OpenAI-compatible fallback (set llm.provider: openai in config.yaml):
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=http://localhost:11434/v1
